# Managed by Ansible (platform role) - do not edit on the host.
[Unit]
Description=Monitoring stack - Prometheus, Loki, Grafana (DHIS2 hosting platform)
After=docker.service
Requires=docker.service

[Service]
Type=simple
WorkingDirectory={{ deploy_dir }}
ExecStart=/usr/bin/docker compose -f stacks/monitoring/docker-compose.yml --env-file stacks/monitoring/.env up
ExecStop=/usr/bin/docker compose -f stacks/monitoring/docker-compose.yml --env-file stacks/monitoring/.env down
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
